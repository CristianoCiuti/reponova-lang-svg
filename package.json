{
  "name": "@reponova/lang-svg",
  "version": "0.1.0",
  "description": "SVG diagram support for RepoNova",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "reponova": "^0.x"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "reponova": "file:../reponova",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "reponova": {
    "type": "language",
    "id": "svg",
    "extensions": [".svg"]
  }
}
